# Copy to .env.development and fill in values:
#   cp .env.development.example .env.development

NODE_ENV=development
PORT=3001
API_VERSION=v1

# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/randevubu?schema=public
# Secrets must be at least 32 characters and DIFFERENT from each other.
# Generate strong values with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace-with-a-local-dev-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-local-dev-secret-32-chars

# Redis
# Running the app directly on your host (npm run dev):
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Running inside docker-compose.dev.yml instead, use:
#   REDIS_HOST=redis
#   REDIS_PASSWORD=redis_SDFS45DG

# Optional in development — CORS defaults to localhost:3000/3001 if unset
# CORS_ORIGINS=http://localhost:3000

LOG_LEVEL=debug

# AWS / S3 — required in production (image & asset uploads), optional in local dev.
# Credentials are picked up by the AWS SDK default chain (env, ~/.aws, IAM role).
# AWS_REGION=eu-central-1
# AWS_S3_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# PUBLIC_ASSET_BASE_URL=
# ASSET_ALLOWED_HOSTS=
# AWS_MAX_ATTEMPTS=3
# AWS_REQUEST_TIMEOUT_MS=15000

# AWS SES (transactional email) — optional in local dev
# AWS_SES_FROM_EMAIL=
# AWS_SES_REPLY_EMAIL=

# Auth cookies — production only (domain for cross-subdomain cookies)
# COOKIE_DOMAIN=

# Google Places — optional for local dev unless testing Google integration
# GOOGLE_PLACES_API_KEY=

# SMS (NetGSM) — optional for local dev unless testing SMS
# NETGSM_USERNAME=
# NETGSM_PASSWORD=
# NETGSM_MSGHEADER=

# Push notifications — optional for local dev
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@randevubu.com

# Payments (Iyzico sandbox) — optional for local dev
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Telemetry (OpenTelemetry) — disabled unless OTEL_ENABLED=true
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=randevubu-server
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=

# HTTPS enforcement is on in production; set to true only behind a proxy that
# already terminates TLS and you need to disable the redirect.
# DISABLE_HTTPS_ENFORCEMENT=false
